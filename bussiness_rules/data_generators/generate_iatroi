N     = 150
TODAY = datetime.date(2026, 5, 13)
# counter starts at 500 to avoid sequence collisions with existing 80 doctors
COUNTER_START = 500

lines = [
    '-- 150 additional doctors using add_doctor procedure',
    '-- Generated by generate_iatros.py',
    '-- Vathmides must already exist in vathmida_iatrou (IDs 1-4)',
    '-- Supervisors are inserted before supervisees (vathmida 1 calls come last)',
    '',
]

# ── Pass 1: generate all records ──────────────────────────────────────────────
records = []  # (amka, onoma, eponymo, ilikia, email, tilefono, hire, ar_ad, eidikotita, vathmida)

for i in range(COUNTER_START, COUNTER_START + N):
    is_male     = random.random() < 0.5
    onoma       = random.choice(male_names   if is_male else female_names)
    eponymo     = random.choice(male_surnames if is_male else female_surnames)
    vathmida    = random.choice(vathmida_pool)
    # Ηλικία: Ειδικευόμενοι 26-35, υπόλοιποι 35-62
    ilikia      = random.randint(26, 35) if vathmida == 1 else random.randint(35, 62)
    email       = f'{to_greeklish(onoma)}.{to_greeklish(eponymo)}{i}@hospital.gr'
    tilefono    = random_phone()
    birth_year  = TODAY.year - ilikia
    birth_month = random.randint(1, 12)
    birth_day   = random.randint(1, 28)
    birth_date  = datetime.date(birth_year, birth_month, birth_day)
    if (birth_month, birth_day) > (TODAY.month, TODAY.day):
        birth_date = datetime.date(birth_year - 1, birth_month, birth_day)
    amka        = gen_amka(birth_date, i, is_male)
    hire        = random_hire_date()
    ar_ad       = gen_ar_ad()
    eidikotita  = random.choice(eidikotites)
    records.append((amka, onoma, eponymo, ilikia, email, tilefono, hire, ar_ad, eidikotita, vathmida))

# ── Pass 2: assign supervisors ────────────────────────────────────────────────
# Supervisors = vathmida 2,3,4 (can_supervise=1)
# Supervisees = vathmida 1 (is_supervised=1)
supervisors = [r[0] for r in records if r[9] >= 2]  # amkas of non-trainee doctors

def get_supervisor(eidikotita):
    """Pick a supervisor amka, preferring same specialty."""
    same = [r[0] for r in records if r[9] >= 2 and r[8] == eidikotita]
    pool = same if same else supervisors
    return random.choice(pool) if pool else 'NULL'

# ── Pass 3: write lines sorted so supervisors come first ──────────────────────
supervisors_records  = [r for r in records if r[9] >= 2]
supervisees_records  = [r for r in records if r[9] == 1]

lines.append('-- ── Supervisors (vathmida 2-4) ─────────────────────────────────────────')
for amka, onoma, eponymo, ilikia, email, tilefono, hire, ar_ad, eidikotita, vathmida in supervisors_records:
    lines.append(
        f"CALL add_doctor('{amka}', '{onoma}', '{eponymo}', {ilikia}, "
        f"'{email}', '{tilefono}', '{hire}', 'Ιατρός', '{ar_ad}', "
        f"'{eidikotita}', {vathmida}, NULL);"
    )

lines.append('')
lines.append('-- ── Supervisees (vathmida 1 - Ειδικευόμενοι) ──────────────────────────')
for amka, onoma, eponymo, ilikia, email, tilefono, hire, ar_ad, eidikotita, vathmida in supervisees_records:
    epoptis = get_supervisor(eidikotita)
    lines.append(
        f"CALL add_doctor('{amka}', '{onoma}', '{eponymo}', {ilikia}, "
        f"'{email}', '{tilefono}', '{hire}', 'Ιατρός', '{ar_ad}', "
        f"'{eidikotita}', {vathmida}, '{epoptis}');"
    )

lines.append('')

with open('load_iatros_data.sql', 'w', encoding='utf-8') as f:
    f.write('\n'.join(lines))

