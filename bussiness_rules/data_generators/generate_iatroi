used_ar_ad = set()
# Δεσμεύουμε τους ήδη υπάρχοντες (ISA-048001 .. ISA-048080)
for i in range(1, 81):
    used_ar_ad.add(f'ISA-{48000 + i:06d}')

ar_ad_counter = [100001]  # mutable counter

def gen_ar_ad():
    while True:
        code = f'ISA-{ar_ad_counter[0]:06d}'
        ar_ad_counter[0] += 1
        if code not in used_ar_ad:
            used_ar_ad.add(code)
            return code

