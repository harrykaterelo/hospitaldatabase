GREEKLISH = {
    'α':'a','ά':'a','β':'v','γ':'g','δ':'d','ε':'e','έ':'e','ζ':'z',
    'η':'i','ή':'i','θ':'th','ι':'i','ί':'i','ϊ':'i','ΐ':'i','κ':'k',
    'λ':'l','μ':'m','ν':'n','ξ':'x','ο':'o','ό':'o','π':'p','ρ':'r',
    'σ':'s','ς':'s','τ':'t','υ':'y','ύ':'y','ϋ':'y','ΰ':'y','φ':'f',
    'χ':'ch','ψ':'ps','ω':'o','ώ':'o',
}

def to_greeklish(text):
    return ''.join(GREEKLISH.get(c, c) for c in text.lower())

used_phones = set()
def random_phone():
    while True:
        phone = '+3069' + str(random.randint(10000000, 99999999))
        if phone not in used_phones:
            used_phones.add(phone)
            return phone

# ─── AMKA generator ───────────────────────────────────────────────────────────
def gen_amka(birth_date: datetime.date, counter: int, is_male: bool):
    dd  = f'{birth_date.day:02d}'
    mm  = f'{birth_date.month:02d}'
    yy  = f'{birth_date.year % 100:02d}'
    seq_num = counter * 2 + (1 if is_male else 0)
    seq     = f'{seq_num:05d}'
    amka    = dd + mm + yy + seq
    attempts = 0
    while amka in used_amkas and attempts < 500:
        seq_num += 2
        seq  = f'{seq_num:05d}'
        amka = dd + mm + yy + seq
        attempts += 1
    used_amkas.add(amka)
    return amka

